// LaunchWake schema. See docs/DATA_MODEL.md.
// Channel is global + seeded (the intelligence asset). Users never create channels.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime uses the pooled connection (serverless-friendly); Prisma migrate /
  // introspect use the direct, unpooled connection via DIRECT_URL.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// Auth + user
// ─────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  emailVerified    DateTime?
  name             String?
  image            String?
  githubId         String?   @unique
  plan             Plan      @default(FREE)
  seats            Int       @default(1) // purchased seats (Team plan); billed per seat
  stripeCustomerId String?
  // Channel ref (a tracked-link short code) captured from the lw_ref cookie at
  // signup. LaunchWake dogfoods its own attribution: when this user pays, the
  // Stripe webhook credits the channel that drove their signup. See lib/billing.
  lwRef            String?
  projects         Project[]
  accounts         Account[]
  sessions         Session[]
  reminders        Reminder[]
  // Team seats: memberships this user owns (they pay) vs is a member of.
  ownedMemberships TeamMembership[] @relation("TeamOwner")
  memberships      TeamMembership[] @relation("TeamMember")
  sentInvites      TeamInvite[]     @relation("TeamInvites")
  brand            Brand? // agency white-label branding (Team)
  lastDigestAt     DateTime? // last weekly digest sent (guards against re-sends)
  // Product-notification emails (weekly digest, plan-ready). Default on; the
  // one-click unsubscribe link and the Settings toggle turn it off. Never
  // gates transactional auth email (magic links).
  emailNotifications Boolean @default(true)
  // Self-reported "how did you hear about us?" answer at signup — LaunchWake
  // dogfooding its own dark-social attribution (a tracked link/UTM can't see the
  // podcast, DM, or word-of-mouth that actually drove the signup). `heardVia` is
  // the normalized source key (see lib/selfReport.ts); null when unanswered.
  heardVia         String?
  heardViaAt       DateTime?
  createdAt        DateTime  @default(now())
}

// Agency white-label branding (Team tier). When set, client reports render with
// the agency's logo/name/accent instead of LaunchWake's — the agency sends the
// report to their client as "our report", and LaunchWake stays the invisible
// engine behind it. One brand per account owner.
model Brand {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agencyName  String
  logoUrl     String? // https or data: URL
  accentColor String? // hex "#rrggbb"
  updatedAt   DateTime @updatedAt
}

// A member occupying one of the owner's Team seats — shares the owner's workspace.
model TeamMembership {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberId  String
  member    User     @relation("TeamMember", fields: [memberId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([ownerId, memberId])
  @@index([memberId])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

// A pending seat invitation (accept link carries the token).
model TeamInvite {
  id         String       @id @default(cuid())
  ownerId    String
  owner      User         @relation("TeamInvites", fields: [ownerId], references: [id], onDelete: Cascade)
  email      String
  token      String       @unique
  status     InviteStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  acceptedAt DateTime?

  @@index([ownerId])
  @@index([email])
}

enum Plan {
  FREE
  PRO
  TEAM
}

// Auth.js (NextAuth) adapter models — keep these.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────
// Product + ships
// ─────────────────────────────────────────────────────────────

// The product the user is marketing (e.g., "Hookline").
model Project {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                 String
  description          String? // used as LLM context for fit scoring
  url                  String?
  // Where this product is in its launch lifecycle. Set at onboarding; branches
  // the journey into Launch Mode (PRE_LAUNCH/UNANNOUNCED) vs Growth Mode
  // (LAUNCHED). Existing projects default to LAUNCHED (already in growth use).
  launchStage          LaunchStage @default(LAUNCHED)
  // Cached launch-readiness snapshot (score + weighted checklist) computed by
  // lib/launchReadiness.ts. Null until the readiness stage runs.
  launchReadinessJson  Json?
  launchReadinessAt    DateTime?
  githubRepo           String? // "owner/repo"
  githubInstallationId String? // for webhook auto-detect
  webhookSecret        String? // per-project GitHub webhook signing secret
  stripeWebhookSecret  String? // the user's Stripe endpoint signing secret (whsec_…) for revenue attribution
  // Last time the LaunchWake pixel pinged /api/track/verify from the user's
  // product — powers the "pixel detected" state on Results/Settings.
  pixelVerifiedAt      DateTime?
  slackWebhookUrl      String? // Slack incoming webhook for reminders / new-ship pings
  ships                Ship[]
  selfReports          SelfReport[] // self-reported "how did you hear" answers from the survey snippet
  events               Event[] // link-less attribution events (unattributed signups) for reconciliation
  intentQueries        IntentQuery[] // Intent Radar: saved "people looking for us" watches
  // White-label client report: a stable, branded link at /report/c/{token}.
  reportToken          String?  @unique
  reportEnabled        Boolean  @default(false)
  createdAt            DateTime @default(now())
}

// A distribution moment: release / feature / blog / other.
model Ship {
  id         String            @id @default(cuid())
  projectId  String
  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type       ShipType
  title      String
  summary    String? // what makes it worth sharing
  sourceUrl  String? // release URL / blog URL
  commitSha  String?
  status     ShipStatus        @default(NEW)
  // Chosen launch date (Launch Mode). Anchors the D-7..D+2 schedule, the
  // launch-day cockpit, and the D-1 reminder. Null until scheduled.
  launchAt   DateTime?
  plan       DistributionPlan?
  posts      Post[]
  queueTasks QueueTask[]
  pitches    NewsletterPitch[]
  detectedAt DateTime          @default(now())
  // Public launch report (the viral loop): a shareable page at /report/{token}.
  // Null token = private. Revenue is hidden unless the owner opts in.
  publicToken       String?  @unique
  publicShowRevenue Boolean  @default(false)
}

// Where a product sits in its launch lifecycle (set at onboarding).
//  PRE_LAUNCH  — not live yet (building toward a first public launch)
//  UNANNOUNCED — live but never formally launched (the "ships in silence" case)
//  LAUNCHED    — already had a public launch → Growth Mode (every-ship cadence)
enum LaunchStage {
  PRE_LAUNCH
  UNANNOUNCED
  LAUNCHED
}

enum ShipType {
  LAUNCH
  FEATURE
  BLOG
  OTHER
}

enum ShipStatus {
  NEW
  PLANNED
  POSTED
  DONE
}

// ─────────────────────────────────────────────────────────────
// Channel intelligence (global, seeded)
// ─────────────────────────────────────────────────────────────

model Channel {
  id             String           @id @default(cuid())
  slug           String           @unique // "hn-show", "r-webdev", "product-hunt"
  name           String // "Hacker News — Show HN"
  platform       Platform
  url            String?
  audienceDesc   String? // "~5M developers, high intent"
  rules          String? // human-readable posting rules
  defaultBanRisk BanRisk          @default(LOW)
  bestTime       String? // "Tue–Thu 8am ET"
  tags           String[] // ["devtools","backend","infra"] for fit matching
  // Optional account-readiness data (age/karma thresholds, profile tips, source).
  // Shape: lib/accountReadiness.ts AccountRequirementsSchema. Drives launch-mode tips.
  accountRequirements Json?
  // Optional cost to submit/list here ({ type: free|paid|freemium, note? }).
  // Absent = free. Shape: lib/channelCost.ts. Drives the plan-card cost badge.
  cost           Json?
  recs           Recommendation[]
  posts          Post[]
  stats          ChannelStat[]
  benchmarks     ChannelBenchmark[]
  queueTasks     QueueTask[]
  pitches        NewsletterPitch[]
}

enum Platform {
  HACKERNEWS
  REDDIT
  PRODUCTHUNT
  INDIEHACKERS
  DEVTO
  LOBSTERS
  X
  LINKEDIN
  DISCORD
  SLACK
  NEWSLETTER
  DIRECTORY
  MASTODON
  BLUESKY
  FORUM
  YOUTUBE
  BLOG
  OTHER
}

enum BanRisk {
  LOW
  MEDIUM
  HIGH
}

// ─────────────────────────────────────────────────────────────
// The hero output: plan + ranked recommendations + drafts
// ─────────────────────────────────────────────────────────────

model DistributionPlan {
  id        String           @id @default(cuid())
  shipId    String           @unique
  ship      Ship             @relation(fields: [shipId], references: [id], onDelete: Cascade)
  recs      Recommendation[]
  createdAt DateTime         @default(now())
}

model Recommendation {
  id        String           @id @default(cuid())
  planId    String
  plan      DistributionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  channelId String
  channel   Channel          @relation(fields: [channelId], references: [id])
  rank      Int              @default(0) // display order, best first
  fitScore  Int // 0..100
  banRisk   BanRisk
  bestTime  String?
  whyText   String // one-line rationale, product-specific
  ruleNote  String? // the safe way in for THIS post
  outcomeNote String? // flywheel evidence, e.g. "Proven: 3.2% conv for dev-tools"
  draft     Draft?
}

model Draft {
  id               String         @id @default(cuid())
  recommendationId String         @unique
  recommendation   Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  platform         Platform
  body             String
  safetyNote       String?
  createdAt        DateTime       @default(now())
}

// ─────────────────────────────────────────────────────────────
// Attribution
// ─────────────────────────────────────────────────────────────

model Post {
  id          String       @id @default(cuid())
  shipId      String
  ship        Ship         @relation(fields: [shipId], references: [id], onDelete: Cascade)
  channelId   String
  channel     Channel      @relation(fields: [channelId], references: [id])
  url         String?
  status      PostStatus   @default(LIVE)
  trackedLink TrackedLink?
  postedAt    DateTime     @default(now())
  // Cached post-mortem coaching (LLM + outcome data). Null until diagnosed.
  coachingJson Json?
  coachedAt   DateTime?
}

enum PostStatus {
  LIVE
  REMOVED
}

model TrackedLink {
  id        String  @id @default(cuid())
  postId    String  @unique
  post      Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  shortCode String  @unique
  destUrl   String
  events    Event[]
}

model Event {
  id            String       @id @default(cuid())
  // Nullable: a link-attributed CLICK/SIGNUP/REVENUE sets this; an *unattributed*
  // SIGNUP (arrived with no lw_ref and no email match) has no link and instead
  // carries `projectId`, so a founder's total signups still reconcile (dark social).
  trackedLinkId String?
  trackedLink   TrackedLink? @relation(fields: [trackedLinkId], references: [id], onDelete: Cascade)
  // Set only for link-less events (unattributed signups) so they roll up to a
  // project without a channel. Null for link-attributed events.
  projectId     String?
  project       Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type          EventType
  // Revenue events carry an amount (smallest currency unit) + currency, and
  // whether it recurs (subscription) so we can attribute MRR to a channel.
  amountCents   Int?
  currency      String?
  recurring     Boolean      @default(false)
  // Idempotency key for CLICK/SIGNUP dedup (see lib/attribution.clickDedupeKey /
  // signupDedupeKey). Null for legacy rows and REVENUE events. Partial unique
  // indexes — (trackedLinkId, type, dedupeKey) for link-attributed rows and
  // (projectId, type, dedupeKey) for link-less rows, both WHERE dedupeKey IS NOT
  // NULL — enforce "record each click/signup at most once". Prisma Migrate can't
  // express partial indexes, so they're created by hand in the migration; inserts
  // use ON CONFLICT DO NOTHING (createMany skipDuplicates).
  dedupeKey     String?
  // sha256(lowercased email), when the click/signup carried one — never the raw
  // email. On a CLICK it powers cross-device recovery (match a later ref-less
  // signup to the channel by email); on a SIGNUP it records which identity converted.
  emailHash     String?
  // Trust flag for REVENUE: true when the amount came from a signature-verified
  // source (the Stripe webhook, LaunchWake's own billing) or an HMAC-signed
  // /api/track/revenue call; false when a public caller supplied an unsigned
  // amount we can't vouch for. Results sums verified revenue separately.
  verified      Boolean      @default(true)
  // Multi-touch: SIGNUP events store the last-3 distinct lw_ref codes seen at
  // conversion in `meta.touches` (most-recent first); the row itself is attributed
  // to touches[0] (last-touch). The rest are kept for future multi-touch modeling.
  meta          Json?
  createdAt     DateTime     @default(now())

  @@index([emailHash])
  @@index([projectId, type])
}

enum EventType {
  CLICK
  SIGNUP
  REVENUE
}

// Self-reported attribution — "how did you hear about us?" answered on the
// customer's signup form (via the survey snippet) or LaunchWake's own signup.
// This is the ONLY signal that catches dark social: a link/UTM sees a click, but
// the podcast, DM, or word-of-mouth that sent someone to type the URL directly
// leaves no click at all. Deliberately NOT tied to a TrackedLink (a self-report
// exists with or without a prior click). `lwRef` records the tracked ref that
// WAS present at the same moment, if any — so we can measure how often link-based
// attribution disagrees with what the human actually said.
model SelfReport {
  id        String    @id @default(cuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // The raw answer (a chosen option label or free text), trimmed + truncated.
  answer    String
  // Normalized coarse source key (see lib/selfReport.ts SELF_REPORT_OPTIONS):
  // "reddit" | "x" | "hackernews" | "podcast" | "word_of_mouth" | "search" | …
  source    String
  // The catalog platform this source maps to, for reconciling against link
  // attribution. Null for sources with no distribution channel (word of mouth,
  // search, a podcast) — those are pure dark social.
  platform  Platform?
  // The lw_ref (tracked-link short code) present when the answer was given, if
  // any. Null = no tracked click preceded this signup (dark social).
  lwRef     String?
  createdAt DateTime  @default(now())

  @@index([projectId, createdAt])
}

// Scheduled "post at the best time" reminder (email/Slack ping — never posts).
model Reminder {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  shipId        String
  channelName   String
  shipTitle     String
  bestTimeLabel String?
  ruleNote      String?
  method        ReminderMethod
  sendAt        DateTime
  status        ReminderStatus @default(PENDING)
  error         String?
  sentAt        DateTime?
  createdAt     DateTime       @default(now())

  @@index([status, sendAt])
}

enum ReminderMethod {
  EMAIL
  SLACK
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELED
}

// Aggregated outcome data per channel (the flywheel / moat).
model ChannelStat {
  id         String   @id @default(cuid())
  channelId  String
  channel    Channel  @relation(fields: [channelId], references: [id])
  productTag String // profile bucket, e.g. "devtools-backend"
  posts      Int      @default(0)
  clicks     Int      @default(0)
  // TRACKED signups (Events) — the verifiable signal the moat/ranking uses.
  signups    Int      @default(0)
  // SELF-REPORTED signups (survey answers) stored ALONGSIDE, never mixed into
  // `signups`: unverifiable, so it never drives ranking, but benchmarks can show
  // "tracked vs reported" later. Split evenly across a project's channels on the
  // same platform to avoid double-counting a coarse answer.
  reportedSignups Int  @default(0)
  removals   Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([channelId, productTag])
}

// Category benchmarks — the paywall trigger. Per (product category, channel)
// aggregate proof shown at the decision moment: "devtool products got a median
// of 34 signups from Show HN." First-party medians (anonymous, across all
// accounts) blended with a public-engagement bootstrap (median upvotes from
// HN/Reddit) so there's a number even before first-party data accumulates.
// Refreshed by rollupBenchmarks(); read-gated to Pro in the UI.
model ChannelBenchmark {
  id            String   @id @default(cuid())
  productTag    String // category bucket, e.g. "devtools-backend"
  channelId     String
  channel       Channel  @relation(fields: [channelId], references: [id])
  // First-party aggregate (anonymous, across all accounts).
  sampleSize    Int      @default(0) // number of posts
  medianSignups Int      @default(0)
  meanSignups   Float    @default(0)
  conversionPct Float    @default(0) // signups / clicks * 100
  // Public-engagement bootstrap (cold start), from HN/Reddit public APIs.
  publicSample  Int      @default(0)
  medianUpvotes Int      @default(0)
  source        String   @default("public") // "first-party" | "public" | "blended"
  updatedAt     DateTime @updatedAt

  @@unique([productTag, channelId])
  @@index([productTag])
}

// Distribution queue — the anti-churn cadence. A launch isn't a day, it's a
// sequence: week 1 directories, week 2 newsletters, week 3 niche subreddits,
// ~month 3 a Show HN relaunch, changelog channels on the release itself. Each
// ship gets a queue of dated tasks; the weekly digest surfaces the ones due
// ("this week's 3 tasks"), which keeps founders coming back. Never auto-posts.
model QueueTask {
  id        String          @id @default(cuid())
  shipId    String
  ship      Ship            @relation(fields: [shipId], references: [id], onDelete: Cascade)
  channelId String
  channel   Channel         @relation(fields: [channelId], references: [id])
  phase     QueuePhase
  dueAt     DateTime // when this task should be worked (surfaced in the digest)
  status    QueueTaskStatus @default(PENDING)
  doneAt    DateTime?
  createdAt DateTime        @default(now())

  @@unique([shipId, channelId, phase])
  @@index([status, dueAt])
  @@index([shipId])
}

enum QueuePhase {
  CHANGELOG // day 0 — announce the release (dev.to / blog)
  DIRECTORIES // week 1 — AlternativeTo, SaaSHub, …
  NEWSLETTERS // week 2 — pitch curated newsletters
  SUBREDDITS // week 3 — niche communities
  SHOW_HN_RELAUNCH // ~month 3 — relaunch on Show HN
}

enum QueueTaskStatus {
  PENDING
  DONE
  SKIPPED
}

// Newsletter Pitch Engine — newsletters aren't posted to, their curator is
// pitched. For each (ship, newsletter) we generate a personalized pitch email
// grounded in that newsletter's audience + selection criteria, then track the
// send and nudge a follow-up if there's no reply. The human sends the email.
model NewsletterPitch {
  id         String      @id @default(cuid())
  shipId     String
  ship       Ship        @relation(fields: [shipId], references: [id], onDelete: Cascade)
  channelId  String
  channel    Channel     @relation(fields: [channelId], references: [id])
  subject    String
  body       String
  status     PitchStatus @default(DRAFT)
  sentAt     DateTime?
  followUpAt DateTime? // when to nudge a follow-up (set on send)
  createdAt  DateTime    @default(now())

  @@unique([shipId, channelId])
  @@index([status, followUpAt])
}

enum PitchStatus {
  DRAFT // generated, not yet sent
  SENT // emailed the curator
  REPLIED // curator replied
  DECLINED // passed / no fit
}

// ─────────────────────────────────────────────────────────────
// Intent Radar — "people looking for your product".
// A saved query watches HN + Reddit for posts/comments where someone is
// asking for a tool like yours ("is there a tool that…?", "alternative to X").
// Each hit becomes an IntentMatch with a ban-safe, human-written draft reply
// the founder posts themselves. Never auto-posts (product principle).
// ─────────────────────────────────────────────────────────────
model IntentQuery {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String // "People asking for attribution tools"
  // Intent phrases to match against post text ("looking for a tool that",
  // "alternative to segment"). Any hit is a candidate.
  phrases    String[]
  // Required topic keywords — a candidate must mention at least one so we don't
  // surface every "looking for a tool" post in the world.
  keywords   String[]
  // Optional subreddit narrowing (slugs, no "r/"). Empty = broad Reddit search.
  subreddits String[]
  active     Boolean       @default(true)
  matches    IntentMatch[]
  createdAt  DateTime      @default(now())

  @@index([projectId])
}

model IntentMatch {
  id        String            @id @default(cuid())
  queryId   String
  query     IntentQuery       @relation(fields: [queryId], references: [id], onDelete: Cascade)
  source    IntentSource
  // Stable id from the source (HN objectID / Reddit fullname) — dedupes ingest.
  externalId String
  title     String
  url       String
  author    String?
  excerpt   String? // snippet of the matched text
  score     Int // 0..100 relevance
  matchReason String? // human "why this matched"
  postedAt  DateTime // when the source post/comment was created
  status    IntentMatchStatus @default(NEW)
  // Ban-safe draft reply (LLM). Null until generated. Human posts it themselves.
  draftBody  String?
  safetyNote String?
  notifiedAt DateTime? // when we alerted the user (guards re-notify)
  createdAt  DateTime          @default(now())

  @@unique([queryId, externalId])
  @@index([status, postedAt])
  @@index([queryId, status])
}

enum IntentSource {
  HN
  REDDIT
}

enum IntentMatchStatus {
  NEW // caught, not yet surfaced
  NOTIFIED // user has been alerted
  SAVED // user starred it
  DISMISSED // user hid it
}

// ─────────────────────────────────────────────────────────────
// Lead capture (public lead-magnet tools, e.g. the Launch Checker).
// A lead is an email + the context that produced it, captured BEFORE
// the person has an account. Deliberately not linked to User: these are
// top-of-funnel and may convert into a User later (matched by email).
// ─────────────────────────────────────────────────────────────
model Lead {
  id          String   @id @default(cuid())
  email       String
  source      String // "launch-checker"
  repo        String? // "owner/repo" the checker ran on
  projectName String?
  // Snapshot of the teaser plan we showed, so we can email/rebuild it later.
  context     Json?
  createdAt   DateTime @default(now())

  @@index([email])
  @@index([source, createdAt])
}

// ─────────────────────────────────────────────────────────────
// Durable counters + idempotency (security hardening)
// The in-memory rate limiter and LLM budget reset on every cold start and
// never held across serverless instances — worthless on Vercel. These tables
// make them durable + shared. Stripe idempotency stops retried events from
// double-applying a plan change.
// ─────────────────────────────────────────────────────────────

// One row per (key, fixed-window). Incremented atomically via ON CONFLICT.
// Stale rows are harmless; a periodic sweep (by resetAt) can prune them.
model RateWindow {
  id      String   @id // "${bucket}:${windowStartMs}"
  count   Int      @default(0)
  resetAt DateTime

  @@index([resetAt])
}

// Per-user daily LLM token spend — the durable budget guard.
model LlmUsageDay {
  id     String @id @default(cuid())
  userId String
  day    String // "YYYY-MM-DD" (UTC)
  tokens Int    @default(0)

  @@unique([userId, day])
  @@index([day])
}

// Stripe delivers the same event.id on retries; claim-once so a re-delivery
// can't double-apply. Released on handler failure so a retry can reprocess.
model ProcessedStripeEvent {
  eventId     String   @id
  type        String
  processedAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// Webhook delivery durability + retry (ingestion resilience)
// Every authentic inbound GitHub/Stripe webhook is persisted BEFORE its effect
// runs, so a transient failure becomes a retryable row instead of a silent data
// gap. A missed Ship or un-attributed payment reads to the founder as "that
// channel didn't work" — the exact wrong conclusion — so we never swallow these.
//
// Idempotency: `dedupeKey` is the payload hash (GitHub) or external event id
// (Stripe). The unique (source, dedupeKey) plus the PROCESSED short-circuit
// guarantee a re-delivery or a retry never creates a duplicate Ship or
// double-counts revenue. Failed rows carry an attempt count + `nextRetryAt`
// (exponential backoff); the retry-webhooks cron reprocesses them.
// ─────────────────────────────────────────────────────────────
model WebhookDelivery {
  id          String                @id @default(cuid())
  source      WebhookSource
  // Null only when we can't match the payload to a project — still logged.
  projectId   String?
  // Idempotency key: sha256 of the raw body (GitHub) / Stripe event id.
  dedupeKey   String
  eventType   String? // "push", "release", "checkout.session.completed", …
  payload     Json // parsed body, replayed on retry (already signature-verified)
  signature   String? // inbound signature header, for the audit trail
  status      WebhookDeliveryStatus @default(RECEIVED)
  error       String? // last failure message (never swallowed)
  attempts    Int                   @default(0)
  // When a FAILED delivery is next eligible for retry (exponential backoff).
  nextRetryAt DateTime?
  shipId      String? // Ship created by this delivery, if any (audit trail)
  receivedAt  DateTime              @default(now())
  processedAt DateTime?
  updatedAt   DateTime              @updatedAt

  @@unique([source, dedupeKey])
  @@index([status, nextRetryAt])
  @@index([projectId, source, status])
  @@index([projectId, receivedAt])
}

enum WebhookSource {
  GITHUB
  STRIPE
}

enum WebhookDeliveryStatus {
  RECEIVED
  PROCESSED
  FAILED
}

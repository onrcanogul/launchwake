# ─────────────────────────────────────────────────────────────
# LaunchWake environment. Copy to `.env.local` and fill in.
# Validated at boot by lib/env.ts (zod). Missing REQUIRED vars fail fast.
# ─────────────────────────────────────────────────────────────

# App URL (used for tracked links, OAuth callbacks, absolute URLs)
APP_URL="http://localhost:3000"

# ── Database (Postgres / Supabase) ── REQUIRED
DATABASE_URL="postgresql://user:password@localhost:5432/launchwake?schema=public"

# ── Auth.js (NextAuth v5) ── REQUIRED
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="replace-me"

# GitHub OAuth (primary login + repo connect). Optional to boot; required for GitHub login.
# Create at https://github.com/settings/developers  (callback: {APP_URL}/api/auth/callback/github)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Email magic-link (optional). Leave EMAIL_SERVER empty to hide the email
# option on /login (GitHub still works). Set BOTH to enable magic links.
#
# Recommended: Resend (resend.com) — free tier, no mail infra to run.
#   1. Create an API key (re_...) in the Resend dashboard.
#   2. Use it as the SMTP password below; the username is literally "resend".
#   3. Testing: onboarding@resend.dev only delivers to your Resend account
#      email. Production: verify your domain in Resend, then use an address
#      on it (e.g. login@launchwake.dev).
#
# Port 465 = implicit TLS, so the scheme MUST be "smtps" (not "smtp"):
#   EMAIL_SERVER="smtps://resend:re_your_api_key@smtp.resend.com:465"
# Port 587 = STARTTLS, uses the plain "smtp" scheme:
#   EMAIL_SERVER="smtp://resend:re_your_api_key@smtp.resend.com:587"
EMAIL_SERVER=""
EMAIL_FROM="LaunchWake <onboarding@resend.dev>"

# ── LLM provider ── "openai" (default) or "anthropic"
LLM_PROVIDER="openai"

# ── OpenAI ── required for analysis + drafts when LLM_PROVIDER=openai (default)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# ── Anthropic Claude ── required for analysis + drafts when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"
# Cost guard: hard cap on input+output tokens per single LLM request.
LLM_MAX_TOKENS_PER_REQUEST="8000"
# Cost guard: hard cap on total tokens a single user may spend per day.
LLM_MAX_TOKENS_PER_USER_DAY="200000"

# ── GitHub API (repo/release fetch for ships) ── optional
# A classic/fine-grained PAT for server-side repo reads when not using the user's OAuth token.
GITHUB_TOKEN=""
# Shared secret configured on the GitHub webhook (ship auto-detect). Signature is
# enforced when set; leave empty to accept unsigned webhooks in local dev.
GITHUB_WEBHOOK_SECRET=""

# ── GitHub App (repo picker incl. private repos) ── optional
# A GitHub App (separate from the login OAuth above) for read-only repo access so
# the repo picker can list private repos without a broad sign-in scope. Create at
# https://github.com/settings/apps — permissions: Contents (read), Metadata
# (read), Webhooks; subscribe to Push + Release; Setup URL {APP_URL}/api/github/setup.
GITHUB_APP_ID=""
# Paste the PEM. In a single-line .env, keep the literal "\n" newlines — they're normalized at runtime.
GITHUB_APP_PRIVATE_KEY=""
# The app's URL slug (github.com/apps/<slug>), for the "Connect GitHub" install link.
GITHUB_APP_SLUG=""
# The App's webhook secret (set in the App settings). Used to verify installation deliveries.
GITHUB_APP_WEBHOOK_SECRET=""

# ── Stripe (Milestone 3) ── optional
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── Jobs (Inngest, Milestone 4) ── optional
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ── Cron: reminder delivery ── the scheduler sends this to /api/cron/reminders
# (header "authorization: Bearer <CRON_SECRET>" or "?secret=<CRON_SECRET>").
CRON_SECRET=""

# ── Product analytics (optional) ── PostHog server-side capture for the
# activation funnel (lib/analytics.ts). Absent → analytics is a silent no-op.
POSTHOG_API_KEY=""
# POSTHOG_HOST="https://us.i.posthog.com"  # or https://eu.i.posthog.com

# ── Error tracking (optional) ── forward captured errors to Sentry. Both are
# optional; absent → Sentry is disabled and tree-shaken out of the build.
# SENTRY_DSN is the server/edge DSN; NEXT_PUBLIC_SENTRY_DSN is the browser DSN
# (usually the same project DSN). Build-time source-map upload additionally uses
# SENTRY_ORG, SENTRY_PROJECT and SENTRY_AUTH_TOKEN (set those in Vercel/CI only).
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_ENVIRONMENT=""            # optional, defaults to VERCEL_ENV / NODE_ENV
# SENTRY_TRACES_SAMPLE_RATE="0.1"  # optional performance-trace sample rate
# SENTRY_ORG=""                    # build-time, for source-map upload
# SENTRY_PROJECT=""                # build-time, for source-map upload
# SENTRY_AUTH_TOKEN=""             # build-time, for source-map upload

# ── SEO (optional) ── Google Search Console verification token (the value from
# the "HTML tag" method) → rendered as a <meta name="google-site-verification">.
GOOGLE_SITE_VERIFICATION=""
